#. Plugin Name of the plugin
msgid "LRob - Calendar"
msgstr "LRob - Calendar"

#. Plugin URI of the plugin
msgid "https://www.lrob.fr/en/wordpress/plugins/lrob-calendar/"
msgstr "https://www.lrob.fr/wordpress/plugins/lrob-calendar/"

#. Description of the plugin
msgid ""
"A powerful and clean event calendar for WordPress with recurring events, "
"categories, locations, import/export and more."
msgstr ""
"Un calendrier d'événements puissant et épuré pour WordPress, avec événements "
"récurrents, catégories, lieux, import/export et plus encore."

#. Author of the plugin
msgid "LRob"
msgstr "LRob"

#. Author URI of the plugin
msgid "https://www.lrob.fr"
msgstr "https://www.lrob.fr"

