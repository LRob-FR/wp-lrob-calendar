{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lrob-calendar/events-list",
    "title": "Events List",
    "description": "List or grid of upcoming events with images, excerpts, and categories.",
    "category": "widgets",
    "icon": "list-view",
    "textdomain": "lrob-calendar",
    "attributes": {
        "limit":          { "type": "number",  "default": 10 },
        "pagination":     { "type": "boolean", "default": false },
        "paginationStyle":{ "type": "string",  "default": "arrows" },
        "category":       { "type": "number",  "default": 0 },
        "tag":            { "type": "number",  "default": 0 },
        "showPast":       { "type": "boolean", "default": true },
        "order":          { "type": "string",  "default": "auto" },
        "template":       { "type": "string",  "default": "list" },
        "showImages":      { "type": "boolean", "default": true },
        "showExcerpt":     { "type": "boolean", "default": true },
        "descriptionMode": { "type": "string",  "default": "inline" },
        "showCategories":  { "type": "boolean", "default": true },
        "imageDisplay":   { "type": "string",  "default": "contain" },
        "imageHeight":    { "type": "string",  "default": "medium" },
        "imagePosition":  { "type": "string",  "default": "right" },
        "imageLightbox":  { "type": "boolean", "default": true }
    },
    "editorScript": "lrob-calendar-block-events-list-edit",
    "editorStyle":  "lrob-calendar-blocks-editor",
    "viewScript":   ["lrob-calendar-event-card-lightbox", "lrob-calendar-event-card-expand", "lrob-calendar-events-list-pagination"],
    "style":        ["lrob-calendar-block-events-list", "lrob-calendar-lightbox"],
    "render":       "file:./render.php"
}
